# ---------------------------------------------------------------------------
# Secrets & environment
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Data — never commit raw pulls or the local database
# ---------------------------------------------------------------------------
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# QA reports are generated artifacts — keep the folder, ignore the contents
qa_reports/*
!qa_reports/.gitkeep

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
